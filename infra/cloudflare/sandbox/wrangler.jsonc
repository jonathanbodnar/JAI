{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jai-sandbox",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "Sandbox",
      // Reference the official Cloudflare Sandbox image directly from Docker
      // Hub so wrangler doesn't need a local Docker daemon to build/push.
      // CRITICAL: use the `-python` variant. The plain `cloudflare/sandbox`
      // tag is JS-only and ships NO python interpreter — every Gmail-style
      // skill fails with "python3: command not found" against the lean image.
      // Skills install extra packages on first run via the prelude in
      // src/index.ts (cached afterwards via marker file).
      "image": "docker.io/cloudflare/sandbox:0.7.21-python",
      // `lite` (256 MiB) gets OOM-killed by pip installs of anything
      // chunky (supabase, postgrest, langchain, etc.). `basic` (1 GiB,
      // 4 GB disk) is enough headroom for the package set JAI skills
      // typically need.
      "instance_type": "basic",
      "max_instances": 8
    }
  ],

  "durable_objects": {
    "bindings": [
      { "class_name": "Sandbox", "name": "Sandbox" }
    ]
  },

  "migrations": [
    { "new_sqlite_classes": ["Sandbox"], "tag": "v1" }
  ],

  "vars": {
    "JAI_SANDBOX_VERSION": "0.1.0"
  },

  "observability": {
    "enabled": true
  }
}
