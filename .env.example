# ============================================================================
# JAI — Second Brain / Founder OS
# Copy to .env and fill in. Never commit .env.
# ============================================================================

# --- LLM (single key, all models via OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=jai
OPENROUTER_APP_URL=https://jai.local

# Model registry (override defaults from packages/agents config)
JAI_MODEL_ORCHESTRATOR=qwen/qwen3.7-max
JAI_MODEL_REFLECTION=moonshotai/kimi-k2.6
JAI_MODEL_STRATEGY=deepseek/deepseek-v4-pro
JAI_MODEL_SKILL_BUILDER=qwen/qwen3.7-max
JAI_MODEL_FAST=deepseek/deepseek-v4-flash:free
JAI_MODEL_EMBED=openai/text-embedding-3-large

# --- Speech ---
GROQ_API_KEY=                      # for Whisper STT (whisper-large-v3-turbo)
ELEVENLABS_API_KEY=                # fallback TTS
KOKORO_TTS_URL=http://localhost:8880   # self-hosted Kokoro on Fly

# --- Memory: Mem0 Cloud ---
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# --- Memory: Qdrant Cloud ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=jai_memory

# --- Memory: Neo4j Aura ---
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- App DB / Auth: Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=                      # postgres connection string for LangGraph checkpointer

# --- Blob storage: Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jai-blobs
R2_PUBLIC_URL=

# --- Skill sandbox: Cloudflare Sandbox SDK ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SANDBOX_BASE_URL=                  # deployed sandbox worker URL
SANDBOX_AUTH_TOKEN=                # shared secret between backend and sandbox worker

# --- Credentials encryption (Fernet key, 44 chars base64 ending with =)
#     generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
JAI_CREDENTIALS_KEY=

# --- Internal MCP server bearer token ---
JAI_MCP_SERVER_TOKEN=

# --- Google OAuth (for "Connect Gmail/Calendar/Drive"; NOT used for Tasks/Notes) ---
# Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application):
#   Authorized JavaScript origins:  https://jai.ftr.me
#   Authorized redirect URIs:       https://api.jai.ftr.me/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.jai.ftr.me/auth/google/callback

# --- Observability: Langsmith (optional, set langsmith_tracing=true to enable) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=jai
LANGSMITH_TRACING=false

# --- App config ---
JAI_USER_ID=                       # owner user id (single-tenant dev fallback)
JAI_BACKEND_URL=https://api.jai.ftr.me
JAI_FRONTEND_URL=https://jai.ftr.me
NEXT_PUBLIC_JAI_BACKEND_URL=https://api.jai.ftr.me
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- (Optional) Operator dashboard credits/status providers ---
# These same keys above are reused — no extra env needed for:
#   OpenRouter, Groq, Qdrant, Cloudflare, ElevenLabs, Mem0, Neo4j, Supabase.
# Add FLY_API_TOKEN if you want Fly machine stats in the Status dashboard.
FLY_API_TOKEN=
