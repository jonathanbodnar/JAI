{
  "name": "jai",
  "version": "0.1.0",
  "private": true,
  "description": "JAI — second brain, founder OS, autonomous operator",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "pnpm --filter @jai/web dev",
    "dev:api": "cd apps/api && uv run uvicorn jai_api.main:app --reload --port 8000",
    "dev:tts": "cd apps/tts && uv run uvicorn tts_service.main:app --reload --port 8880",
    "dev:all": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset",
    "gen:types": "bash scripts/gen-types.sh",
    "gen:types:live": "openapi-typescript http://localhost:8000/openapi.json -o packages/shared-types/src/generated/api.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
