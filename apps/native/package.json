{
  "name": "@jai/native",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor wrapper for the JAI PWA — iOS (and Android) App Store distribution.",
  "scripts": {
    "init:ios": "cap add ios",
    "init:android": "cap add android",
    "sync": "cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios --target=\"iPhone 16\"",
    "build:web": "cd ../web && pnpm build && pnpm export 2>/dev/null || pnpm build",
    "copy:web": "cap copy"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/push-notifications": "^6.0.3",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2",
    "@capacitor/app": "^6.0.2",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor-community/safe-area": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.6.3"
  }
}
